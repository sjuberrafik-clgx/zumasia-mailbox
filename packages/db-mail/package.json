{
    "name": "@zumasia/db-mail",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "migrate:local": "wrangler d1 migrations apply zumasia-mail --local",
        "migrate:remote": "wrangler d1 migrations apply zumasia-mail --remote",
        "create:local": "wrangler d1 create zumasia-mail",
        "exec:local": "wrangler d1 execute zumasia-mail --local --file=seed.sql"
    },
    "devDependencies": {
        "wrangler": "^4.100.0"
    }
}